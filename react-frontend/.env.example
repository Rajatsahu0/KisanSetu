# API Configuration - GCP
VITE_API_BASE_URL=http://localhost:5001
VITE_API_TIMEOUT=60000

# Production API (uncomment when deploying)
# VITE_API_BASE_URL=https://kisansetu-api-XXXXXXXX.asia-south1.run.app

# GCP Configuration
VITE_GCP_PROJECT_ID=your-gcp-project-id

# Application Configuration
VITE_APP_NAME=KisanSetu
VITE_APP_VERSION=2.0.0
VITE_DEFAULT_LANGUAGE=hi

# Feature Flags
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_VOICE_QUERIES=true
VITE_ENABLE_ANALYTICS=false

# Development
VITE_ENABLE_DEVTOOLS=true
VITE_LOG_LEVEL=debug
